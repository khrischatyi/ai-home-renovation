# ======================================================================
# PRODUCTION .env — copy to `/home/<user>/ai-home-renovation/.env` on the
# AWS server and fill in the real values.
#
#   scp .env.prod.filled ubuntu@helpico.ai:/home/ubuntu/ai-home-renovation/.env
#
# After editing on the server run `./deploy.sh` (or `make deploy` locally).
# ======================================================================

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=renovation
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD
POSTGRES_DB=renovation
DATABASE_URL=postgresql+asyncpg://renovation:REPLACE_WITH_A_STRONG_RANDOM_PASSWORD@db:5432/renovation
DATABASE_URL_SYNC=postgresql://renovation:REPLACE_WITH_A_STRONG_RANDOM_PASSWORD@db:5432/renovation

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth (JWT) ──────────────────────────────────────────────
# Generate with:  python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=REPLACE_WITH_A_48_BYTE_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Stripe ──────────────────────────────────────────────────
# While validating, paste the same test keys you're using locally
# (from `.env`). Switch to pk_live_… / sk_live_… to take real charges.
# Do NOT commit the real values — fill them on the server only.
STRIPE_SECRET_KEY=sk_test_PASTE_YOUR_TEST_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_TEST_PUBLISHABLE_KEY_HERE
# Register a production webhook endpoint in the Stripe dashboard
# (https://dashboard.stripe.com/test/webhooks for test mode)
# pointing at:   https://helpico.ai/api/v1/payments/webhook
# Then paste the whsec_… it shows you below:
STRIPE_WEBHOOK_SECRET=whsec_PASTE_WEBHOOK_SIGNING_SECRET_HERE
# Stripe expands {CHECKOUT_SESSION_ID}; our service expands {PROJECT_ID}.
STRIPE_SUCCESS_RETURN_URL=https://helpico.ai/project/{PROJECT_ID}/payment/return?session_id={CHECKOUT_SESSION_ID}

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["https://helpico.ai","https://www.helpico.ai"]

# ─── App ─────────────────────────────────────────────────────
# DEBUG=false is critical — this flips cookies to `Secure` (requires HTTPS).
DEBUG=false
APP_NAME=AI Home Renovation Platform

# ─── Domain (used by Caddyfile.prod for auto-TLS) ────────────
DOMAIN=helpico.ai
